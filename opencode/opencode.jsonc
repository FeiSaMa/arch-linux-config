{
  "$schema": "https://opencode.ai/config.json",

  // ============================================================
  // DeepSeek 模型策略配置
  // 根据任务复杂度自动路由到不同模型以达到最大性价比
  // ============================================================

  // 默认使用 V4-Flash（平衡速度与能力）
  "model": "deepseek/deepseek-v4-flash",

  // 默认使用 code agent（省钱优先）
  "default_agent": "code",

  "provider": {
    "deepseek": {
      "options": {
        "timeout": 600000,
        "chunkTimeout": 30000
      },
      "models": {
        "deepseek-v4-flash": {
          "cost": {
            "input": 1,
            "output": 2
          }
        },
        "deepseek-v4-pro": {
          "cost": {
            "input": 4,
            "output": 16
          }
        }
      }
    }
  },

  "instructions": ["~/.config/opencode/instructions/system.md"],

  "references": {
    "arch-linux-config": {
      "path": "~/refs/arch-linux-config",
      "description": "Arch Linux system configuration docs — use for /etc/ config files, packages, services, dotfiles, and hardware tuning (see hardware/ subdirectory)"
    }
  },

  "lsp": true,

  // ============================================================
  // 上下文压缩配置
  // ============================================================
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },

  // ============================================================
  // Agent 体系：4 个专用 Agent 覆盖不同复杂度场景
  // ============================================================
  "agent": {
    // ---- Tab 顺序: plan → build → code → create ----
    "plan": {
      "mode": "all",
      "model": "deepseek/deepseek-v4-flash",
      "description": "规划与探索 Agent — 代码分析、方案设计、代码库探索，只读模式",
      "color": "#81C784",
      "temperature": 0.1,
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    },
    "build": {
      "mode": "all",
      "model": "deepseek/deepseek-v4-pro",
      "description": "默认开发 Agent，用于复杂代码编写、架构设计、重构等需要深度推理的任务",
      "color": "#4FC3F7",
      "temperature": 0.5,
      "steps": 20,
      "permission": {
        "edit": "allow",
        "bash": "allow"
      }
    },
    "code": {
      "mode": "all",
      "model": "deepseek/deepseek-v4-flash",
      "description": "编码专用 Agent，低温度高确定性，适合代码生成与修改",
      "color": "#FFB74D",
      "temperature": 0.2,
      "top_p": 0.9,
      "permission": {
        "edit": "allow",
        "bash": "allow"
      }
    },
    "create": {
      "mode": "all",
      "model": "deepseek/deepseek-v4-flash",
      "description": "创意生成 Agent — 头脑风暴、内容创作、概念设计，较高温度 + top_p 约束保持可控",
      "color": "#E57373",
      "temperature": 0.8,
      "top_p": 0.95,
      "permission": {
        "edit": "allow",
        "bash": "allow"
      }
    }
  }
}
