#!/usr/bin/env bash
set -euo pipefail

BAT="/sys/class/power_supply/BAT0"
THRESH="$BAT/charge_control_end_threshold"
CMD="${1:-}"

usage() {
    echo "Usage: bat-charge {save|full|status}"
    echo "  save   - charge limit 80% (battery saver, daily plugged-in)"
    echo "  full   - charge limit 100% (full range, going out)"
    echo "  status - show current threshold and capacity"
    exit 1
}

[ -f "$THRESH" ] || { echo "ERROR: $THRESH not found or not supported" >&2; exit 1; }

case "$CMD" in
    save)
        [ -w "$THRESH" ] && echo 80 > "$THRESH" || pkexec sh -c "echo 80 > $THRESH"
        echo "Charge threshold set to 80% (battery saver)"
        ;;
    full)
        [ -w "$THRESH" ] && echo 100 > "$THRESH" || pkexec sh -c "echo 100 > $THRESH"
        echo "Charge threshold set to 100% (full range)"
        ;;
    status)
        cur=$(cat "$THRESH")
        cap=$(cat "$BAT/capacity")
        echo "Threshold: ${cur}%  |  Battery: ${cap}%"
        [ "$cur" -eq 80 ] && echo "Mode: battery saver" || echo "Mode: full range"
        ;;
    *)
        usage
        ;;
esac
