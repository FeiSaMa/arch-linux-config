#!/usr/bin/env python3
import json, time, os, urllib.request, sys
from datetime import datetime

CONFIG = os.path.expanduser("~/.local/share/io.github.clash-verge-rev.clash-verge-rev")
SECRET = open(f"{CONFIG}/config.yaml").read().split("secret: ")[1].split("\n")[0]
API = "http://127.0.0.1:9097"

def api(path):
    req = urllib.request.Request(f"{API}{path}", headers={"Authorization": f"Bearer {SECRET}"})
    try: return json.loads(urllib.request.urlopen(req, timeout=2).read())
    except: return {}

def fmt(b):
    for u in ("B", "KB", "MB", "GB"):
        if abs(b) < 1024: return f"{b:.1f}{u}"
        b /= 1024
    return f"{b:.1f}TB"

known = set()
while True:
    data = api("/connections")
    conns = data.get("connections", [])
    up = sum(c.get("upload", 0) for c in conns)
    down = sum(c.get("download", 0) for c in conns)

    now = {c["id"] for c in conns}
    new_ids = now - known
    known = now

    os.system("clear")
    print(f"\033[36m\033[1m  ThinkPad Router - 实时网络请求  \033[0m")
    print(f"\033[33m  活跃: {len(conns)}  \u2191 {fmt(up)}  \u2193 {fmt(down)}  |  {time.strftime('%H:%M:%S')}\033[0m")
    print(f"  {'=' * 60}")
    print(f"  {'时间':<8} {'主机':<26} {'目标':<20} {'代理':<10}")
    print(f"  {'=' * 60}")

    for c in conns:
        m = c.get("metadata", {})
        host = m.get("host", "") or m.get("destinationIP", "")
        dst = f"{m.get('destinationIP','?')}:{m.get('destinationPort','?')}"
        chain = (c.get("chains") or ["?"])[0]
        start = c.get("start", "")
        try:
            t = datetime.fromisoformat(start).strftime("%H:%M:%S")
        except:
            t = ""
        mark = " \033[32mNEW\033[0m" if c["id"] in new_ids else "   "
        print(f"  {t:<8} {host[:25]:<26} {dst[:19]:<20} {chain[:9]:<10}{mark}")

    sys.stdout.flush()
    time.sleep(2)
